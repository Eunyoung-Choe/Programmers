[ 타 풀이 1 ]
// 내 풀이 수식을 재귀함수로 풀어낸 형태
class Solution {
    public long solution(int balls, int share) { // 여기도 long으로 바꿨네.
        share = Math.min(balls - share, share);

        if (share == 0)
            return 1;

        long result = solution(balls - 1, share - 1); // 본 메서드 자체를 재귀
        result *= balls;
        result /= share;

        return result;
    }
}

