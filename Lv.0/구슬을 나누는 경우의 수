// 나는 대체 언제 수식 고수가 되는가.
// 팩토리얼은 int 크기를 넘어설 정도로 크기가 커질 수 있어 계산은 long에 담아야 함!!
class Solution {
    public int solution(int balls, int share) {
        // for문에서 변수도 증감식도 여러 변수가 가능하나 조건식은 반드시 하나여야 한다고.
        long answer = 1;
        
        for (int i=1; i<=share; i++) {
            answer = answer * (balls - i + 1) / i;
        }
        
        return (int)answer;
}

